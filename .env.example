# === Backend ===

# Database
DATABASE_URL=postgresql://nexthire:nexthire@db:5432/nexthire

# AWS Bedrock (primary LLM provider)
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_DEFAULT_REGION=eu-central-1

# LLM Configuration
LLM_PROVIDER=bedrock
LLM_FAST_MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0
LLM_POWER_MODEL=eu.anthropic.claude-sonnet-4-20250514-v1:0

# App
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:3000

# === Frontend (.env.local) ===
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
